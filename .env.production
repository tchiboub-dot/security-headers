# Production environment variables for Vercel deployment
# For Vercel: Set DATABASE_URL in your Vercel project settings
# Use a PostgreSQL database URL for production (e.g., from Supabase, Railway, or Render)
DATABASE_URL="postgresql://user:password@host:5432/database"

# Application
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NODE_ENV="production"
